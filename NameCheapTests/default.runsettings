<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <!-- Avoid parallel tests because it doesn't work well with the Sandbox API -->
    <MaxCpuCount>1</MaxCpuCount>
    <Parallelize><Workers>1</Workers><Scope>MethodLevel</Scope></Parallelize>
  </RunConfiguration>
 </RunSettings>